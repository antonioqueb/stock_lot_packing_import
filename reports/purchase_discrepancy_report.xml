<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_purchase_discrepancy" model="ir.actions.report">
        <field name="name">Reporte de Discrepancia</field>
        <field name="model">purchase.discrepancy</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">stock_lot_packing_import.report_purchase_discrepancy</field>
        <field name="report_file">stock_lot_packing_import.report_purchase_discrepancy</field>
        <field name="print_report_name">'Discrepancia - %s' % (object.name or '')</field>
        <field name="binding_model_id" ref="model_purchase_discrepancy"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_purchase_discrepancy">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <t t-set="address" t-value="False"/>
                    <t t-set="information_block" t-value="False"/>

                    <div class="page" style="font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; font-size: 10px; color: #222; line-height: 1.25;">
                        <t t-call="stock_lot_dimensions.som_report_style"/>

                        <!-- ============ TÍTULO ============ -->
                        <div class="row border-bottom pb-2 mb-2" style="border-color: #2f2f2f !important; align-items: center;">
                            <div class="col-8">
                                <h4 class="som-doc-title mb-0">
                                    Discrepancia
                                    <span t-field="doc.name" style="margin-left: 10px; color: #555;"/>
                                </h4>
                            </div>
                            <div class="col-4 text-end">
                                <div class="som-doc-subtitle" style="margin: 4px 0 0 0;">
                                    Impreso: <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y %H:%M')"/>
                                </div>
                            </div>
                        </div>

                        <!-- ============ INFORMACIÓN GENERAL (3 columnas) ============ -->
                        <div style="margin-bottom: 12px;">
                            <table style="font-size: 9px; width: 100%; border-collapse: collapse; border: 1px solid #d8d8d8 !important; table-layout: fixed;">
                                <colgroup>
                                    <col style="width: 34%;"/>
                                    <col style="width: 33%;"/>
                                    <col style="width: 33%;"/>
                                </colgroup>
                                <thead>
                                    <tr>
                                        <th class="som-section-title">Proveedor</th>
                                        <th class="som-section-title">Recepción</th>
                                        <th class="som-section-title">Discrepancia</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <!-- PROVEEDOR -->
                                        <td style="vertical-align: top; padding: 0; border: 1px solid #d8d8d8 !important;">
                                            <div style="padding: 6px 8px; overflow-wrap: anywhere; word-break: break-word;">
                                                <span style="font-weight: bold; font-size: 11px;" t-field="doc.partner_id.name"/>
                                                <span t-if="doc.partner_id.vat" class="som-small som-muted" style="display: block; margin-top: 2px;">RFC: <span t-field="doc.partner_id.vat"/></span>
                                            </div>
                                        </td>

                                        <!-- RECEPCIÓN -->
                                        <td style="vertical-align: top; padding: 0; border: 1px solid #d8d8d8 !important;">
                                            <div class="som-info-row">
                                                <div class="som-info-label">Orden de Compra</div>
                                                <div class="som-info-value"><t t-esc="doc.purchase_id.name or doc.origin or '-'"/></div>
                                            </div>
                                            <div class="som-info-row">
                                                <div class="som-info-label">Contenedor</div>
                                                <div class="som-info-value"><t t-esc="doc.container_no or '-'"/></div>
                                            </div>
                                            <div class="som-info-row">
                                                <div class="som-info-label">Fecha Recepción</div>
                                                <div class="som-info-value">
                                                    <span t-if="doc.scheduled_date" t-field="doc.scheduled_date" t-options='{"widget": "date"}'/>
                                                    <span t-else="" class="som-muted">-</span>
                                                </div>
                                            </div>
                                        </td>

                                        <!-- DISCREPANCIA -->
                                        <td style="vertical-align: top; padding: 0; border: 1px solid #d8d8d8 !important;">
                                            <div class="som-info-row">
                                                <div class="som-info-label" style="width: 45%;">Tipo</div>
                                                <div class="som-info-value" style="text-align: right;"><span t-field="doc.discrepancy_type"/></div>
                                            </div>
                                            <div class="som-info-row">
                                                <div class="som-info-label" style="width: 45%;">Estado</div>
                                                <div class="som-info-value" style="text-align: right;"><span t-field="doc.state"/></div>
                                            </div>
                                            <div class="som-info-row">
                                                <div class="som-info-label" style="width: 45%;">Reportó</div>
                                                <div class="som-info-value" style="text-align: right;"><t t-esc="doc.reported_by.name or '-'"/></div>
                                            </div>
                                            <div class="som-info-row">
                                                <div class="som-info-label" style="width: 45%;">Fecha</div>
                                                <div class="som-info-value" style="text-align: right;"><span t-field="doc.date" t-options='{"widget": "datetime"}'/></div>
                                            </div>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <!-- ============ PRODUCTOS AFECTADOS (Comprado / Recibido / Afectada) ============ -->
                        <div class="som-section-title som-avoid-break" style="margin-top: 14px; margin-bottom: 5px;">Productos afectados</div>
                        <t t-set="alines" t-value="doc.line_ids.filtered(lambda l: l.qty_affected &gt; 0)"/>
                        <t t-if="alines">
                            <table class="som-table">
                                <thead>
                                    <tr>
                                        <th class="text-center" style="width: 4%;">#</th>
                                        <th style="width: 28%;">Producto</th>
                                        <th class="text-end" style="width: 13%;">Cant. comprada</th>
                                        <th class="text-end" style="width: 15%;">Cant. con discrepancia</th>
                                        <th class="text-center" style="width: 8%;">UDM</th>
                                        <th class="text-end" style="width: 14%;">Costo de compra</th>
                                        <th class="text-end" style="width: 18%;">Monto afectado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-set="lseq" t-value="1"/>
                                    <t t-foreach="alines" t-as="ln">
                                        <tr>
                                            <td class="text-center"><span t-esc="lseq"/><t t-set="lseq" t-value="lseq + 1"/></td>
                                            <td><strong t-field="ln.product_id.display_name"/></td>
                                            <td class="som-num"><span t-esc="'%.2f' % (ln.qty_purchased or 0.0)"/></td>
                                            <td class="som-num" style="font-weight: bold;"><span t-esc="'%.2f' % (ln.qty_affected or 0.0)"/></td>
                                            <td class="text-center"><span t-esc="ln.product_uom_id.name or ''"/></td>
                                            <td class="som-num"><span t-field="ln.unit_cost" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                            <td class="som-num" style="font-weight: bold;"><span t-field="ln.amount_affected" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                        </tr>
                                    </t>
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td colspan="6" class="text-end" style="border-top: 2px solid #2f2f2f; font-weight: 800; text-transform: uppercase;">Monto afectado total</td>
                                        <td class="som-num" style="border-top: 2px solid #2f2f2f; font-weight: 800;"><span t-field="doc.amount_affected" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </t>
                        <t t-else="">
                            <div class="som-muted" style="font-size: 9px; font-style: italic; padding: 6px 0;">No se marcó cantidad afectada en ningún producto.</div>
                        </t>

                        <!-- ============ DESCRIPCIÓN ============ -->
                        <div class="som-section-title som-avoid-break" style="margin-top: 14px; margin-bottom: 5px;">Descripción</div>
                        <div style="border: 1px solid #d8d8d8; padding: 8px; background-color: #f7f7f7; white-space: pre-line; font-size: 9.5px; line-height: 1.35;">
                            <t t-esc="doc.description or '-'"/>
                        </div>

                        <!-- ============ EVIDENCIAS ============ -->
                        <t t-if="doc.evidence_ids">
                            <div class="som-section-title som-avoid-break" style="margin-top: 14px; margin-bottom: 5px;">Evidencias (<t t-esc="len(doc.evidence_ids)"/>)</div>
                            <div class="row">
                                <t t-foreach="doc.evidence_ids" t-as="ev">
                                    <div class="col-6 som-avoid-break" style="margin-bottom: 10px;">
                                        <div style="border: 1px solid #d8d8d8; border-radius: 3px; padding: 6px;">
                                            <div style="font-size: 9px; font-weight: 700; margin-bottom: 4px;"><t t-esc="ev.name or ev.filename or 'Evidencia'"/></div>
                                            <t t-if="ev.is_image and ev.attachment">
                                                <img t-att-src="image_data_uri(ev.attachment)" style="max-width: 100%; max-height: 230px;"/>
                                            </t>
                                            <t t-else="">
                                                <div class="som-small som-muted">Archivo adjunto: <t t-esc="ev.filename or '-'"/></div>
                                            </t>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </t>

                        <!-- ============ RESOLUCIÓN ============ -->
                        <t t-if="doc.resolution_note">
                            <div class="som-section-title som-avoid-break" style="margin-top: 14px; margin-bottom: 5px;">Resolución</div>
                            <div style="border: 1px solid #d8d8d8; padding: 8px; background-color: #f7f7f7; white-space: pre-line; font-size: 9.5px; line-height: 1.35;">
                                <t t-esc="doc.resolution_note"/>
                            </div>
                        </t>

                        <!-- ============ FIRMAS ============ -->
                        <div class="som-avoid-break" style="margin-top: 45px; width: 100%;">
                            <div class="row">
                                <div class="col-1"></div>
                                <div class="col-4 text-center">
                                    <div style="border-top: 1px solid #000; padding-top: 5px;">
                                        <strong style="font-size: 9px; text-transform: uppercase;">Reportó — Almacén</strong>
                                    </div>
                                </div>
                                <div class="col-2"></div>
                                <div class="col-4 text-center">
                                    <div style="border-top: 1px solid #000; padding-top: 5px;">
                                        <strong style="font-size: 9px; text-transform: uppercase;">Visto Bueno — Compras</strong>
                                    </div>
                                </div>
                                <div class="col-1"></div>
                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
