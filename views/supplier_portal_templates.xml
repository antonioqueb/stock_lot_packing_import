<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- PORTAL-REDESIGN-004:
         Template mínimo para que la nueva app controle toda la estructura visual.
         El payload sigue llegando desde SupplierPortalProformaService.build_portal_view(). -->
    <template id="supplier_portal_view" name="Supplier Portal Modern">
        <t t-call="web.frontend_layout">
            <t t-set="no_header" t-value="True"/>
            <t t-set="no_footer" t-value="True"/>

            <div id="portal-data-store"
                 t-att-data-payload="portal_json"
                 style="display:none;"
                 data-noncommentable="1"/>

            <div id="supplier-modern-root" class="spm-boot">
                <div class="spm-loading">
                    <div class="spm-loading-logo">SG</div>
                    <div class="spm-loading-text">Cargando portal del proveedor…</div>
                </div>
            </div>
        </t>
    </template>

    <template id="portal_not_found" name="Supplier Portal Not Found">
        <t t-call="web.frontend_layout">
            <div class="spm-public-message">
                <div class="spm-public-card">
                    <h1>Portal no disponible</h1>
                    <p>El enlace no existe o ya no es válido.</p>
                </div>
            </div>
        </t>
    </template>

    <template id="portal_expired" name="Supplier Portal Expired">
        <t t-call="web.frontend_layout">
            <div class="spm-public-message">
                <div class="spm-public-card">
                    <h1>Enlace expirado</h1>
                    <p>Solicita un nuevo enlace a tu contacto de SOM GROUP.</p>
                </div>
            </div>
        </t>
    </template>
</odoo>
