<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_supplier_cargo_invoice_form" model="ir.ui.view">
        <field name="name">supplier.cargo.invoice.form</field>
        <field name="model">supplier.cargo.invoice</field>
        <field name="arch" type="xml">
            <form string="Factura de Carga">
                <header>
                    <button name="action_generate_link" type="object"
                            string="Generar enlace del portal" class="btn-primary"
                            icon="fa-link"
                            invisible="not purchase_ids"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_purchases" type="object"
                                class="oe_stat_button" icon="fa-shopping-cart"
                                invisible="not purchase_count">
                            <field name="purchase_count" widget="statinfo" string="Órdenes"/>
                        </button>
                        <button name="action_view_shipments" type="object"
                                class="oe_stat_button" icon="fa-ship"
                                invisible="not shipment_count">
                            <field name="shipment_count" widget="statinfo" string="Embarques"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name" string="Factura de carga del proveedor"/>
                        <h1><field name="name" placeholder="No. de factura de carga / embarque"/></h1>
                    </div>
                    <field name="missing_pi_names" invisible="1"/>
                    <div class="alert alert-warning" role="alert"
                         invisible="not missing_pi_names">
                        <i class="fa fa-exclamation-triangle me-2"/>
                        Sin No. de PI capturado: <field name="missing_pi_names" readonly="1" class="fw-bold"/>.
                        Captúralo en cada OC para la trazabilidad PI ↔ PO.
                    </div>
                    <group>
                        <group string="Datos de la carga">
                            <field name="date"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="amount_total"/>
                        </group>
                        <group string="Portal del proveedor">
                            <field name="portal_url" widget="CopyClipboardChar" readonly="1"
                                   invisible="not portal_url"/>
                            <field name="capture_progress" widget="progressbar"
                                   invisible="not portal_url"/>
                            <field name="last_access" invisible="not portal_url"/>
                            <field name="access_expiration" invisible="not portal_url"/>
                            <div class="text-muted" colspan="2" invisible="portal_url">
                                Genera el enlace del portal para que el proveedor
                                capture sus Packing Lists de toda la carga en un solo lugar.
                            </div>
                        </group>
                    </group>
                    <group>
                        <group string="Material">
                            <field name="ordered_display"/>
                            <field name="shipped_display"/>
                            <field name="pending_display"/>
                        </group>
                        <group string="Logística">
                            <field name="packing_count"/>
                            <field name="container_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="PO / PI amparadas" name="purchases">
                            <field name="purchase_ids" nolabel="1">
                                <list>
                                    <field name="name"/>
                                    <field name="partner_ref" string="No. PI / Referencia"/>
                                    <field name="date_order" widget="date" string="Fecha OC"/>
                                    <field name="user_id" string="Comprador" optional="show"/>
                                    <field name="amount_total" sum="Total"/>
                                    <field name="currency_id" column_invisible="1"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state in ('purchase', 'done')"/>
                                </list>
                            </field>
                            <div class="text-muted mt-2">
                                <field name="pi_summary" readonly="1" nolabel="1"/>
                            </div>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_supplier_cargo_invoice_list" model="ir.ui.view">
        <field name="name">supplier.cargo.invoice.list</field>
        <field name="model">supplier.cargo.invoice</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="partner_id"/>
                <field name="pi_summary" string="PO / PI"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="amount_total" sum="Total" optional="show"/>
                <field name="shipped_display" string="Embarcado" optional="show"/>
                <field name="capture_progress" widget="progressbar" optional="show"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'linked'"
                       decoration-success="state in ('shipped', 'closed')"/>
            </list>
        </field>
    </record>

    <record id="action_supplier_cargo_invoice" model="ir.actions.act_window">
        <field name="name">Facturas de Carga</field>
        <field name="res_model">supplier.cargo.invoice</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Registra la primera factura de carga</p>
            <p>Agrupa varias PO/PI del mismo proveedor en un solo enlace de portal.</p>
        </field>
    </record>

    <menuitem id="menu_supplier_cargo_invoice"
              name="Facturas de Carga"
              parent="purchase.menu_purchase_root"
              action="action_supplier_cargo_invoice"
              sequence="26"/>

    <!-- Multi-select en la lista de OCs: crear la carga con las seleccionadas -->
    <record id="action_server_create_cargo_from_pos" model="ir.actions.server">
        <field name="name">Crear Factura de Carga (enlace único)</field>
        <field name="model_id" ref="purchase.model_purchase_order"/>
        <field name="binding_model_id" ref="purchase.model_purchase_order"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = env['supplier.cargo.invoice'].action_create_from_purchases(records.ids)</field>
    </record>

    <!-- PI del proveedor visible en la OC -->
    <record id="view_purchase_order_form_pi" model="ir.ui.view">
        <field name="name">purchase.order.form.supplier.pi</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_ref']" position="attributes">
                <attribute name="string">Referencia / PI del proveedor</attribute>
            </xpath>
            <xpath expr="//sheet" position="before">
                <div class="alert alert-warning" role="alert"
                     invisible="state not in ('purchase', 'done') or partner_ref">
                    <i class="fa fa-exclamation-triangle me-2"/>
                    <strong>Falta la Referencia / PI del proveedor.</strong>
                    Captúrala para poder generar el enlace del portal: sin la PI,
                    la operación no aparecerá correctamente en el portal del proveedor.
                </div>
            </xpath>
        </field>
    </record>

</odoo>
