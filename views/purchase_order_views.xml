<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_order_form_inherit_supplier_portal" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.supplier.portal</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">
                <button name="action_open_supplier_link_wizard"
                        string="Portal Proveedor (PL)"
                        type="object"
                        class="btn-dark"
                        icon="fa-share-alt"
                        invisible="state not in ('purchase', 'done')"/>

                <button name="action_download_vucem"
                        string="Descargar VUCEM"
                        type="object"
                        class="btn-success"
                        icon="fa-download"
                        invisible="not has_vucem_documents"/>
            </xpath>

            <xpath expr="//field[@name='order_line']/list/field[@name='product_qty']" position="after">
                <field name="x_qty_solicitada_original"
                       string="Solicitado Original"
                       optional="show"
                       readonly="1"/>
                <field name="x_qty_embarcada"
                       string="Embarcado (PL)"
                       optional="show"
                       readonly="1"/>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="Links Portal" invisible="not supplier_access_ids">
                    <field name="supplier_access_ids">
                        <list create="0" delete="0" edit="0">
                            <field name="create_date" string="Generado"/>
                            <field name="expiration_date"/>
                            <field name="is_expired" widget="boolean_toggle"/>
                            <field name="portal_url" widget="CopyClipboardChar" readonly="1"/>
                        </list>
                    </field>

                    <div class="alert alert-info" role="alert">
                        El portal del proveedor ya no se liga a una sola recepción.
                        <br/>
                        El link abre la captura general de la OC y cada embarque crea su propia recepción.
                    </div>
                </page>

                <page string="VUCEM" invisible="not has_vucem_documents">
                    <field name="has_vucem_documents" invisible="1"/>
                    <field name="vucem_document_count" invisible="1"/>

                    <div class="alert alert-info" role="alert">
                        <strong><i class="fa fa-file-pdf-o"/> Documentos VUCEM</strong>
                        <p>Se encontraron <field name="vucem_document_count" readonly="1"/> documentos (portal + pagos internos).</p>
                        <p>Al descargar, los PDFs serán convertidos a escala de grises y procesados automáticamente.</p>
                        <p>Los archivos no-PDF se incluyen tal cual. Todo se organiza en subcarpetas Documentos/ y Pagos/.</p>
                    </div>

                    <button name="action_download_vucem"
                            string="Descargar Carpeta VUCEM"
                            type="object"
                            class="btn-primary btn-lg"
                            icon="fa-download"/>

                    <field name="vucem_document_ids" readonly="1">
                        <list create="0" delete="0" edit="0">
                            <field name="document_type"/>
                            <field name="name"/>
                            <field name="file_size"/>
                            <field name="dpi_value"/>
                            <field name="mime_type"/>
                            <field name="create_date" string="Subido"/>
                        </list>
                    </field>
                </page>

                <page string="Pagos Proveedor">
                    <group>
                        <group>
                            <field name="payment_document_count" readonly="1"/>
                            <field name="has_payment_documents" invisible="1"/>
                        </group>
                    </group>

                    <div class="alert alert-info" role="alert">
                        <strong><i class="fa fa-money"/> Documentos de Pago</strong>
                        <p>Los anticipos, pagos por invoice y otros comprobantes se gestionan desde aquí.</p>
                        <p>Estos documentos se incluirán automáticamente en la descarga VUCEM.</p>
                    </div>

                    <field name="payment_document_ids" context="{'default_purchase_id': id, 'default_document_type': 'advance_payment'}">
                        <list editable="bottom">
                            <field name="purchase_id" invisible="1"/>
                            <field name="shipment_id" invisible="1"/>
                            <field name="proforma_id" invisible="1"/>
                            <field name="document_type"/>
                            <field name="name"/>
                            <field name="file_data" filename="name"/>
                            <field name="file_size" readonly="1"/>
                            <field name="mime_type" invisible="1"/>
                            <field name="notes"/>
                            <field name="create_date" string="Subido" readonly="1"/>
                        </list>
                    </field>
                </page>
            </xpath>

        </field>
    </record>
</odoo>