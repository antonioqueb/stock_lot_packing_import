<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="stock_lot_packing_import.SupplierPortalApp">
        <div class="o_portal_wrapper">
            <!-- payload -->
            <div id="portal-data-store"
                 t-att-data-payload="payload_json or '{}'"/>

            <!-- HEADER -->
            <header class="o_portal_header">
                <div class="brand">
                    <i class="fa fa-cubes me-2"/>
                    <span id="portal-vendor-name">PROVEEDOR</span>
                </div>

                <div class="header-controls">
                    <div class="lang-selector-wrapper">
                        <select id="lang-selector" class="lang-select">
                            <option value="es">ES</option>
                            <option value="en">EN</option>
                            <option value="zh">中文</option>
                        </select>
                    </div>

                    <div class="po-info">
                        <div>
                            <span class="label" data-i18n="po_label">Orden de Compra:</span>
                            <span class="value" id="portal-po-name">-</span>
                        </div>
                        <div>
                            <span class="label" data-i18n="receipt_label">Recepción:</span>
                            <span class="value" id="portal-picking-name">-</span>
                        </div>
                    </div>
                </div>
            </header>

            <!-- CONTENT -->
            <div class="o_portal_container">
                <!-- GLOBALS -->
                <div class="shipment-card">
                    <div class="card-header">
                        <i class="fa fa-globe fa-lg"/>
                        <h3 data-i18n="sec_proforma_globals">Datos Globales de la Proforma</h3>
                        <span id="proforma-status-badge" class="badge-status status-draft">Draft</span>
                    </div>

                    <div class="card-body">
                        <div class="modern-form-grid">
                            <div class="form-group">
                                <label data-i18n="lbl_proforma">No. Proforma (PI)</label>
                                <input type="text" id="g-proforma-number" class="form-control" data-i18n-placeholder="ph_proforma" placeholder="Ej. PI-9920"/>
                            </div>

                            <div class="form-group">
                                <label data-i18n="lbl_invoice_global">Factura Global</label>
                                <input type="text" id="g-invoice-global" class="form-control"/>
                            </div>

                            <div class="form-group">
                                <label data-i18n="lbl_payment">Condiciones de Pago</label>
                                <input type="text" id="g-payment-terms" class="form-control" data-i18n-placeholder="ph_payment" placeholder="Ej. T/T 30%"/>
                            </div>

                            <div class="form-group">
                                <label data-i18n="lbl_country">País Origen</label>
                                <input type="text" id="g-country-origin" class="form-control" data-i18n-placeholder="ph_country" placeholder="Ej. China"/>
                            </div>

                            <div class="form-group">
                                <label data-i18n="lbl_port_origin">Puerto Origen</label>
                                <input type="text" id="g-port-origin" class="form-control" data-i18n-placeholder="ph_origin" placeholder="Ej. Shanghai"/>
                            </div>

                            <div class="form-group">
                                <label data-i18n="lbl_port_dest">Puerto Destino</label>
                                <input type="text" id="g-port-destination" class="form-control" data-i18n-placeholder="ph_dest" placeholder="Ej. Manzanillo"/>
                            </div>

                            <div class="form-group">
                                <label data-i18n="lbl_incoterm">Incoterm</label>
                                <input type="text" id="g-incoterm" class="form-control" data-i18n-placeholder="ph_incoterm" placeholder="Ej. CIF"/>
                            </div>

                            <div class="form-group full-width">
                                <label data-i18n="lbl_general_notes">Observaciones Generales</label>
                                <textarea id="g-general-notes" class="form-control" rows="3"></textarea>
                            </div>
                        </div>

                        <div class="text-end mt-3">
                            <button type="button" id="btn-save-globals" class="btn-save-section">
                                <i class="fa fa-save me-2"/>
                                <span data-i18n="btn_save_globals">Guardar Datos Globales</span>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- SHIPMENTS SECTION -->
                <div class="shipments-section">
                    <div class="section-header-bar">
                        <div class="section-title">
                            <i class="fa fa-ship"></i>
                            <h3 data-i18n="sec_shipments">Embarques</h3>
                            <span id="shipment-count-badge" class="shipment-count-badge">0</span>
                        </div>

                        <button type="button" id="btn-add-shipment" class="btn-add-shipment">
                            <i class="fa fa-plus me-2"></i>
                            <span data-i18n="btn_add_shipment">Agregar Embarque</span>
                        </button>
                    </div>

                    <div id="shipments-container">
                        <div class="empty-state" id="no-shipments-msg">
                            <i class="fa fa-inbox fa-3x"></i>
                            <p data-i18n="msg_no_shipments">No hay embarques registrados. Presione 'Agregar Embarque' para comenzar.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- FOOTER -->
            <div class="submit-footer">
                <div class="summary">
                    <div>
                        <span data-i18n="footer_total_shipments">Embarques:</span>
                        <span id="total-shipments" class="text-accent">0</span>
                    </div>
                    <div>
                        <span data-i18n="footer_total_containers">Contenedores:</span>
                        <span id="total-containers" class="text-accent">0</span>
                    </div>
                    <div>
                        <span data-i18n="footer_total_invoices">Invoices:</span>
                        <span id="total-invoices" class="text-accent">0</span>
                    </div>
                </div>

                <button id="btn-complete-proforma" class="btn-primary-custom" disabled="disabled">
                    <i class="fa fa-paper-plane me-2"/>
                    <span data-i18n="btn_complete">Marcar como Completa</span>
                </button>
            </div>
        </div>
    </t>
</templates>